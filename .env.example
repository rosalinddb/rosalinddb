# RosalindDB — environment overrides for docker-compose.
#
# Copy this file to `.env` (same directory as docker-compose.yml) and uncomment
# any variable you want to override. Docker Compose reads `.env` automatically
# and substitutes the values into `docker-compose.yml`'s ${VAR:-default} blocks.
#
# Defaults in docker-compose.yml are OSS-friendly: auth OFF, quotas OFF, a
# known dev JWT secret. That makes `git clone && docker compose up` work
# end-to-end with zero config. The variables below are the knobs a production
# self-hoster turns on top of that.
#
# Anything you do NOT uncomment stays at the OSS default.

# Turn on the JWT + API-key auth stack. Defaults to false (every request
# resolves to a built-in `default` tenant). Set to true when you put the
# stack behind a real domain — the CP will reject requests without a
# Bearer token.
# RB_REQUIRE_AUTH=true

# Turn on the per-tenant vector cap and token-bucket rate limiter. Independent
# of RB_REQUIRE_AUTH; both default off for self-hosters.
# RB_ENABLE_QUOTAS=true

# HS256 JWT signing secret. MUST be set for any non-localhost deploy — the
# dev default below is checked into the public repo. Generate one with:
#   openssl rand -hex 32
# JWT_SECRET=
