# RosalindDB — environment overrides for docker-compose.
#
# Copy this file to `.env` (same directory as docker-compose.yml) and uncomment
# any variable you want to override. Docker Compose reads `.env` automatically
# and substitutes the values into `docker-compose.yml`'s ${VAR:-default} blocks.
#
# Defaults in docker-compose.yml are OSS-friendly: auth OFF, quotas OFF, a
# known dev JWT secret. That makes `git clone && docker compose up` work
# end-to-end with zero config. The variables below are the knobs a production
# self-hoster turns on top of that.
#
# Anything you do NOT uncomment stays at the OSS default.

# Turn on the JWT + API-key auth stack. Defaults to false (every request
# resolves to a built-in `default` tenant). Set to true when you put the
# stack behind a real domain — the CP will reject requests without a
# Bearer token.
# RB_REQUIRE_AUTH=true

# Turn on the per-tenant vector cap and token-bucket rate limiter. Independent
# of RB_REQUIRE_AUTH; both default off for self-hosters.
# RB_ENABLE_QUOTAS=true

# HS256 JWT signing secret. MUST be set for any non-localhost deploy — the
# dev default below is checked into the public repo. Generate one with:
#   openssl rand -hex 32
# JWT_SECRET=

# --- Recall tier — read-your-writes. DEFAULT OFF. ---------------------------
#
# The recall tier adds a small, synchronously-writable, immediately-queryable
# tier (a SEPARATE data-plane pgvector instance) in front of the immutable
# FAISS shards, and unions the two at query time (see
# docs/architecture/recall-consolidate.md). It is entirely opt-in: leave the two
# variables below commented and `docker compose up` behaves byte-identically to
# today — the bundled `pgvector` container just sits idle and healthy, and no
# service ever connects to it.
#
# RB_RECALL_DSN points the recall path at the data-plane pgvector instance.
# Setting it turns on recall-schema migration (the `migrator` applies the recall
# schema) and lets the services connect. The value below targets the bundled
# `pgvector` service. Blank/unset = off.
# RB_RECALL_DSN=postgresql://postgres:postgres@pgvector:5432/recall

# RB_RECALL is the master switch for the recall-tier behaviour (sync recall
# write, query union, consolidation worker). Default off. Independent of
# RB_RECALL_DSN: RB_RECALL_DSN provisions/addresses the store; RB_RECALL turns
# the feature on.
# RB_RECALL=true

# RB_RECALL_POOL_MAX caps the per-process recall connection pool (the app-side
# pool against RB_RECALL_DSN, mirroring the control-plane pool). Default 10.
# Tune it under the recall instance's connection cap when many worker processes
# run side by side. Independent of the control-plane RB_PG_POOL_MAX.
# RB_RECALL_POOL_MAX=10

# Running recall behind pgbouncer (prod / horizontal scale). Point RB_RECALL_DSN
# at a pgbouncer in TRANSACTION pooling mode that targets the recall pgvector db,
# the way Postgres is run in prod:
#   RB_RECALL_DSN=postgresql://postgres:postgres@pgbouncer:6432/recall
# The recall code path is transaction-mode safe: every recall op is a single
# self-contained transaction on one app-side checkout, and recall connections
# create no named server-side prepared statements (adapters/state/state.py,
# `_recall_connect`). pgbouncer's value is multiplexing MANY app replicas
# (sum of app-side pools >> the recall instance's backend cap) onto a small
# server pool — NOT a single-host speedup (the app-side pool already amortises
# connect cost). See bench/docker-compose.recall-bench.yml for a wired example
# and docs/architecture/recall-consolidate.md, "Running recall behind pgbouncer".
